@model List<ApparelShop.Models.Product>
@{ ViewData["Title"] = "Products"; int page = ViewBag.Page; int totalPages = ViewBag.TotalPages; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="mb-0">Products</h3>
    <a asp-action="Create" class="btn btn-accent"><i class="bi bi-plus-lg me-1"></i>Add Product</a>
</div>

<form method="get" class="mb-3 d-flex" style="max-width:300px;">
    <input type="text" name="q" value="@ViewBag.Query" class="form-control form-control-sm me-2" placeholder="Search by name or SKU" />
    <button class="btn btn-sm btn-outline-dark-custom">Search</button>
</form>

<div class="stat-card p-0">
    <table class="table mb-0 align-middle">
        <thead class="table-light">
            <tr><th>Image</th><th>Name</th><th>Category</th><th>Price</th><th>Stock</th><th>Status</th><th></th></tr>
        </thead>
        <tbody>
            @foreach (var p in Model)
            {
                <tr>
                    <td><img src="@(p.MainImageUrl ?? "/images/hero.svg")" style="width:44px;height:56px;object-fit:cover;" /></td>
                    <td>@p.Name <div class="small text-muted">@p.Sku</div></td>
                    <td>@p.Category?.Name</td>
                    <td>AED @p.Price.ToString("0.00")</td>
                    <td>
                        @if (p.StockQuantity <= 5)
                        {
                            <span class="text-danger">@p.StockQuantity</span>
                        }
                        else
                        {
                            @p.StockQuantity
                        }
                    </td>
                    <td>
                        @if (p.IsActive)
                        {
                            <span class="badge bg-success">Active</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Hidden</span>
                        }
                        @if (p.IsFeatured)
                        {
                            <span class="badge bg-warning text-dark">Featured</span>
                        }
                    </td>
                    <td class="text-end">
                        <a asp-action="Edit" asp-route-id="@p.Id" class="btn btn-sm btn-outline-dark-custom">Edit</a>
                        <form asp-action="Delete" asp-route-id="@p.Id" method="post" class="d-inline" onsubmit="return confirm('Delete this product?');">
                            @Html.AntiForgeryToken()
                            <button class="btn btn-sm btn-outline-danger">Delete</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (totalPages > 1)
{
    <nav class="mt-3">
        <ul class="pagination">
            @for (int i = 1; i <= totalPages; i++)
            {
                <li class="page-item @(i == page ? "active" : "")"><a class="page-link" href="?page=@i&q=@ViewBag.Query">@i</a></li>
            }
        </ul>
    </nav>
}
