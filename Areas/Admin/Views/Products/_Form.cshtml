@model ApparelShop.Models.Product
@using ApparelShop.Models
@{
    var categories = ViewBag.Categories as List<Category> ?? new();
    bool isEdit = Model.Id != 0;
}

<form asp-action="@(isEdit ? "Edit" : "Create")" asp-route-id="@(isEdit ? Model.Id : (int?)null)" method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="All" class="text-danger mb-3"></div>

    <div class="row g-4">
        <div class="col-md-8">
            <div class="stat-card mb-3">
                <h6 class="mb-3">Basic Information</h6>
                <div class="mb-3">
                    <label class="form-label">Product Name</label>
                    <input asp-for="Name" class="form-control" required />
                </div>
                <div class="mb-3">
                    <label class="form-label">URL Slug (leave blank to auto-generate)</label>
                    <input asp-for="Slug" class="form-control" placeholder="e.g. silk-slip-dress" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Short Description</label>
                    <input asp-for="ShortDescription" class="form-control" maxlength="300" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Full Description</label>
                    <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                </div>
            </div>

            <div class="stat-card mb-3">
                <h6 class="mb-3">Pricing & Inventory</h6>
                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label">Price (AED)</label>
                        <input asp-for="Price" type="number" step="0.01" class="form-control" required />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Compare-at Price (optional)</label>
                        <input asp-for="CompareAtPrice" type="number" step="0.01" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Stock Quantity</label>
                        <input asp-for="StockQuantity" type="number" class="form-control" required />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">SKU</label>
                        <input asp-for="Sku" class="form-control" required />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Category</label>
                        <select asp-for="CategoryId" class="form-select" required>
                            <option value="">Select category</option>
                            @foreach (var c in categories)
                            {
                                <option value="@c.Id" selected="@(c.Id == Model.CategoryId)">@c.Name</option>
                            }
                        </select>
                    </div>
                </div>
            </div>

            <div class="stat-card mb-3">
                <h6 class="mb-3">Variants & Materials</h6>
                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label">Sizes (comma-separated)</label>
                        <input asp-for="Sizes" class="form-control" placeholder="S,M,L,XL" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Colors (comma-separated)</label>
                        <input asp-for="Colors" class="form-control" placeholder="Black,Navy,White" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Material</label>
                        <input asp-for="Material" class="form-control" />
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="stat-card mb-3">
                <h6 class="mb-3">Visibility</h6>
                <div class="form-check mb-2">
                    <input asp-for="IsActive" class="form-check-input" type="checkbox" checked="@Model.IsActive" />
                    <label class="form-check-label">Active (visible in store)</label>
                </div>
                <div class="form-check mb-2">
                    <input asp-for="IsFeatured" class="form-check-input" type="checkbox" checked="@Model.IsFeatured" />
                    <label class="form-check-label">Featured on homepage</label>
                </div>
                <div class="form-check mb-2">
                    <input asp-for="IsNewArrival" class="form-check-input" type="checkbox" checked="@Model.IsNewArrival" />
                    <label class="form-check-label">Mark as New Arrival</label>
                </div>
            </div>

            <div class="stat-card mb-3">
                <h6 class="mb-3">Main Image</h6>
                @if (!string.IsNullOrEmpty(Model.MainImageUrl))
                {
                    <img src="@Model.MainImageUrl" class="img-fluid mb-2" style="max-height:180px;object-fit:cover;" />
                }
                <input type="file" name="mainImage" class="form-control" accept="image/*" />
            </div>

            @if (isEdit)
            {
                <div class="stat-card mb-3">
                    <h6 class="mb-3">Gallery Images</h6>
                    <div class="d-flex flex-wrap gap-2 mb-3">
                        @foreach (var img in Model.Images.OrderBy(i => i.DisplayOrder))
                        {
                            <div class="position-relative">
                                <img src="@img.ImageUrl" style="width:70px;height:90px;object-fit:cover;" />
                                <form asp-action="DeleteImage" method="post" class="position-absolute top-0 end-0">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="imageId" value="@img.Id" />
                                    <input type="hidden" name="productId" value="@Model.Id" />
                                    <button class="btn btn-sm btn-danger p-0 px-1" style="font-size:0.7rem;" title="Remove">&times;</button>
                                </form>
                            </div>
                        }
                    </div>
                    <label class="form-label small">Add more images</label>
                    <input type="file" name="galleryImages" class="form-control" accept="image/*" multiple />
                </div>
            }
            else
            {
                <div class="stat-card mb-3">
                    <h6 class="mb-3">Gallery Images</h6>
                    <input type="file" name="galleryImages" class="form-control" accept="image/*" multiple />
                </div>
            }
        </div>
    </div>

    <button type="submit" class="btn btn-accent px-4">@(isEdit ? "Save Changes" : "Create Product")</button>
    <a asp-action="Index" class="btn btn-outline-dark-custom px-4">Cancel</a>
</form>
