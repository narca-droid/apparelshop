@using ApparelShop.Services
@inject SiteSettingsService SettingsService
@{
    var settings = await SettingsService.GetAsync();
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] | @settings.SiteName Admin</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body style="background:#f5f6f8;">
    <div class="d-flex">
        <div class="admin-sidebar" style="width:230px;position:sticky;top:0;height:100vh;">
            <div class="brand">@settings.SiteName <span class="d-block" style="font-size:0.7rem;color:#888;font-family:var(--font-sans);letter-spacing:0.1em;">ADMIN PANEL</span></div>
            <nav class="nav flex-column">
                <a class="nav-link @(currentController == "Dashboard" ? "active" : "")" asp-area="Admin" asp-controller="Dashboard" asp-action="Index"><i class="bi bi-speedometer2 me-2"></i>Dashboard</a>
                <a class="nav-link @(currentController == "Products" ? "active" : "")" asp-area="Admin" asp-controller="Products" asp-action="Index"><i class="bi bi-tags me-2"></i>Products</a>
                <a class="nav-link @(currentController == "Categories" ? "active" : "")" asp-area="Admin" asp-controller="Categories" asp-action="Index"><i class="bi bi-grid me-2"></i>Categories</a>
                <a class="nav-link @(currentController == "Orders" ? "active" : "")" asp-area="Admin" asp-controller="Orders" asp-action="Index"><i class="bi bi-bag-check me-2"></i>Orders</a>
                <a class="nav-link @(currentController == "Reviews" ? "active" : "")" asp-area="Admin" asp-controller="Reviews" asp-action="Index"><i class="bi bi-chat-square-text me-2"></i>Reviews</a>
                <a class="nav-link @(currentController == "Content" ? "active" : "")" asp-area="Admin" asp-controller="Content" asp-action="Index"><i class="bi bi-file-earmark-text me-2"></i>Content Pages</a>
                <a class="nav-link @(currentController == "Settings" ? "active" : "")" asp-area="Admin" asp-controller="Settings" asp-action="Index"><i class="bi bi-palette me-2"></i>Site & Layout</a>
                <a class="nav-link @(currentController == "AuditLog" ? "active" : "")" asp-area="Admin" asp-controller="AuditLog" asp-action="Index"><i class="bi bi-clock-history me-2"></i>Audit Log</a>
                <hr style="border-color:#333;" />
                <a class="nav-link" href="/" target="_blank"><i class="bi bi-box-arrow-up-right me-2"></i>View Store</a>
                <form asp-controller="Account" asp-action="Logout" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="nav-link border-0 bg-transparent w-100 text-start"><i class="bi bi-box-arrow-right me-2"></i>Logout</button>
                </form>
            </nav>
        </div>
        <div class="flex-grow-1">
            <div class="admin-content">
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show">@TempData["Success"]<button class="btn-close" data-bs-dismiss="alert"></button></div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show">@TempData["Error"]<button class="btn-close" data-bs-dismiss="alert"></button></div>
                }
                @RenderBody()
            </div>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
