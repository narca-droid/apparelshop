@model List<ApparelShop.Models.AuditLog>
@{ ViewData["Title"] = "Audit Log"; }

<h3 class="mb-4">Audit Log</h3>

<div class="stat-card p-0">
    <table class="table mb-0 align-middle">
        <thead class="table-light">
            <tr><th>Date</th><th>User</th><th>Action</th><th>Entity</th><th>Details</th></tr>
        </thead>
        <tbody>
            @foreach (var log in Model)
            {
                <tr>
                    <td class="small">@log.CreatedAt.ToString("dd MMM yyyy, HH:mm")</td>
                    <td class="small">@log.UserName</td>
                    <td><span class="badge bg-secondary">@log.Action</span></td>
                    <td class="small">@log.Entity @(log.EntityId.HasValue ? $"#{log.EntityId}" : "")</td>
                    <td class="small text-muted">@log.Details</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (ViewBag.TotalPages > 1)
{
    <nav class="mt-3">
        <ul class="pagination pagination-sm justify-content-center">
            @for (int i = 1; i <= (int)ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == (int)ViewBag.Page ? "active" : "")">
                    <a class="page-link" href="?page=@i">@i</a>
                </li>
            }
        </ul>
    </nav>
}
