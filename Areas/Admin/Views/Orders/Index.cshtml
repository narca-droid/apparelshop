@model List<ApparelShop.Models.Order>
@using ApparelShop.Models
@{ ViewData["Title"] = "Orders"; }

<h3 class="mb-4">Orders</h3>

<div class="mb-3">
    <a href="?status=" class="btn btn-sm @(string.IsNullOrEmpty(ViewBag.StatusFilter) ? "btn-accent" : "btn-outline-dark-custom")">All</a>
    @foreach (var s in Enum.GetValues<OrderStatus>())
    {
        <a href="?status=@s" class="btn btn-sm @(ViewBag.StatusFilter == s.ToString() ? "btn-accent" : "btn-outline-dark-custom")">@s</a>
    }
</div>

<form asp-action="Export" method="get" class="mb-3">
    <input type="hidden" name="status" value="@ViewBag.StatusFilter" />
    <button type="submit" class="btn btn-sm btn-outline-dark-custom"><i class="bi bi-download me-1"></i>Export CSV</button>
</form>

<form asp-action="BulkUpdateStatus" method="post" id="bulkForm">
    @Html.AntiForgeryToken()
    <div class="stat-card p-0">
        <table class="table mb-0 align-middle">
            <thead class="table-light">
                <tr>
                    <th style="width:40px;"><input type="checkbox" id="selectAll" class="form-check-input" /></th>
                    <th>Order #</th><th>Customer</th><th>Total</th><th>Status</th><th>Date</th><th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var o in Model)
                {
                    <tr class="@(o.Status == OrderStatus.Pending ? "table-warning" : "")">
                        <td><input type="checkbox" name="orderIds" value="@o.Id" class="form-check-input order-checkbox" /></td>
                        <td>
                            @o.OrderNumber
                            @if (o.Status == OrderStatus.Pending)
                            {
                                <i class="bi bi-exclamation-circle text-warning ms-1" title="Needs confirmation call"></i>
                            }
                        </td>
                        <td>
                            @o.CustomerName
                            <div class="small text-muted">@o.CustomerEmail</div>
                            @if (o.Status == OrderStatus.Pending)
                            {
                                <a href="tel:@o.CustomerPhone" class="small text-decoration-none"><i class="bi bi-telephone"></i> @o.CustomerPhone</a>
                            }
                        </td>
                        <td>AED @o.Total.ToString("0.00")</td>
                        <td><span class="badge bg-secondary">@o.Status</span></td>
                        <td>@o.CreatedAt.ToString("dd MMM yyyy, HH:mm")</td>
                        <td class="text-end">
                            <a asp-action="Details" asp-route-id="@o.Id" class="btn btn-sm btn-outline-dark-custom">View</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="mt-3 d-flex align-items-center gap-2" id="bulkActions" style="display:none !important;">
        <select name="status" class="form-select form-select-sm" style="width:auto;">
            @foreach (var s in Enum.GetValues<OrderStatus>())
            {
                <option value="@s">@s</option>
            }
        </select>
        <button type="submit" class="btn btn-sm btn-accent">Update Selected</button>
    </div>
</form>

@section Scripts {
<script>
    document.getElementById('selectAll')?.addEventListener('change', function() {
        document.querySelectorAll('.order-checkbox').forEach(cb => cb.checked = this.checked);
        toggleBulkActions();
    });
    document.querySelectorAll('.order-checkbox').forEach(cb => cb.addEventListener('change', toggleBulkActions));
    function toggleBulkActions() {
        const checked = document.querySelectorAll('.order-checkbox:checked').length;
        document.getElementById('bulkActions').style.display = checked > 0 ? 'flex' : 'none';
    }
</script>
}
