@model List<ApparelShop.Models.ProductReview>
@using ApparelShop.Models
@{ ViewData["Title"] = "Reviews"; }

<h3 class="mb-4">Customer Reviews</h3>

@{
    var filter = (string?)ViewBag.Filter;
    var pendingCount = (int)ViewBag.PendingCount;
    var totalCount = (int)ViewBag.TotalCount;
    var allClass = filter == null ? "btn-accent" : "btn-outline-dark-custom";
    var pendingClass = filter == "pending" ? "btn-accent" : "btn-outline-dark-custom";
    var approvedClass = filter == "approved" ? "btn-accent" : "btn-outline-dark-custom";
}

<div class="mb-3">
    <a href="?filter=" class="btn btn-sm @allClass">All (@totalCount)</a>
    <a href="?filter=pending" class="btn btn-sm @pendingClass">Pending (@pendingCount)</a>
    <a href="?filter=approved" class="btn btn-sm @approvedClass">Approved</a>
</div>

@if (!Model.Any())
{
    <div class="stat-card text-center py-5">
        <i class="bi bi-chat-square-text" style="font-size:3rem;color:#ddd;"></i>
        <p class="text-muted mt-3">No reviews found.</p>
    </div>
}
else
{
    foreach (var review in Model)
    {
        var badgeClass = review.IsApproved ? "bg-success" : "bg-warning";
        var badgeText = review.IsApproved ? "Approved" : "Pending";
        <div class="stat-card mb-3">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <div class="d-flex align-items-center gap-2 mb-1">
                        <strong>@review.ReviewerName</strong>
                        <span class="badge @badgeClass">@badgeText</span>
                        <span class="text-warning small">
                            @for (var i = 1; i <= 5; i++)
                            {
                                var starClass = i <= review.Rating ? "bi-star-fill" : "bi-star";
                                <i class="bi @starClass"></i>
                            }
                        </span>
                    </div>
                    <div class="small text-muted mb-1">
                        @review.ReviewerEmail &middot; @review.CreatedAt.ToString("dd MMM yyyy")
                        &middot; Product: <a href="/shop/product/@(review.Product!.Slug)" target="_blank">@review.Product!.Name</a>
                    </div>
                    <h6 class="mb-1 mt-2" style="font-size:0.95rem;">@review.Title</h6>
                    @if (!string.IsNullOrEmpty(review.Body))
                    {
                        <p class="small text-muted mb-0">@review.Body</p>
                    }
                </div>
                <div class="d-flex gap-2 flex-shrink-0 ms-3">
                    @if (!review.IsApproved)
                    {
                        <form asp-action="Approve" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@review.Id" />
                            <button type="submit" class="btn btn-sm btn-outline-success"><i class="bi bi-check-lg me-1"></i>Approve</button>
                        </form>
                    }
                    <form asp-action="Delete" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@review.Id" />
                        <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Delete this review permanently?')"><i class="bi bi-trash me-1"></i>Delete</button>
                    </form>
                </div>
            </div>
        </div>
    }

    var totalPages = (int)ViewBag.TotalPages;
    var currentPage = (int)ViewBag.Page;
    if (totalPages > 1)
    {
        <nav class="mt-4">
            <ul class="pagination justify-content-center">
                @if (currentPage > 1)
                {
                    <li class="page-item"><a class="page-link" href="?page=@(currentPage - 1)&filter=@filter">&laquo; Prev</a></li>
                }
                @for (var p = 1; p <= totalPages; p++)
                {
                    var activeClass = p == currentPage ? "active" : "";
                    <li class="page-item @activeClass"><a class="page-link" href="?page=@p&filter=@filter">@p</a></li>
                }
                @if (currentPage < totalPages)
                {
                    <li class="page-item"><a class="page-link" href="?page=@(currentPage + 1)&filter=@filter">Next &raquo;</a></li>
                }
            </ul>
        </nav>
    }
}
