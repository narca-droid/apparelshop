@using ApparelShop.Services
@inject SiteSettingsService SettingsService
@{
    var settings = await SettingsService.GetAsync();
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@(ViewData["Title"] != null ? ViewData["Title"] + " | " + settings.SiteName : settings.MetaTitle)</title>
    <meta name="description" content="@settings.MetaDescription" />
    <link rel="icon" href="@(string.IsNullOrEmpty(settings.FaviconUrl) ? "/favicon.svg" : settings.FaviconUrl)" />

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        :root {
            --color-primary: @settings.PrimaryColor;
            --color-accent: @settings.AccentColor;
            --color-bg: @settings.BackgroundColor;
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    @await Component.InvokeAsync("SiteSettings", new { section = "Header" })

    <main>
        @if (TempData["Success"] != null)
        {
            <div data-toast-success="@TempData["Success"]" class="d-none"></div>
        }
        @if (TempData["Error"] != null)
        {
            <div data-toast-error="@TempData["Error"]" class="d-none"></div>
        }
        @RenderBody()
    </main>

    @await Component.InvokeAsync("SiteSettings", new { section = "Footer" })

    <div id="toast-container" class="toast-container"></div>

    <form id="antiForgeryForm" method="post" style="display:none;">@Html.AntiForgeryToken()</form>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
