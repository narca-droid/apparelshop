@using ApparelShop.ViewComponents
@{
    ViewData["Title"] = "Page Not Found";
}

<div class="container my-5">
    <div class="text-center" style="min-height:50vh;display:flex;flex-direction:column;align-items:center;justify-content:center;">
        <div style="font-size:clamp(4rem,10vw,7rem);font-family:var(--font-serif);font-weight:700;color:var(--color-accent);line-height:1;letter-spacing:-2px;">404</div>
        <h2 class="mt-3 display-font" style="font-size:1.8rem;">Page Not Found</h2>
        <p class="text-muted mt-2 mb-4" style="max-width:400px;line-height:1.7;">
            The page you're looking for doesn't exist or has been moved. Let's get you back on track.
        </p>
        <div class="d-flex gap-3">
            <a href="/" class="btn btn-accent">
                <i class="bi bi-house me-1"></i> Back to Home
            </a>
            <a href="/shop" class="btn btn-outline-dark-custom">
                Browse Shop
            </a>
        </div>
    </div>
</div>
