@using ApparelShop.ViewComponents
@{ ViewData["Title"] = "Contact Us"; }

<div class="container my-5">
    @await Component.InvokeAsync("Breadcrumbs", new List<BreadcrumbItem>
    {
        new() { Text = "Home", Url = "/" },
        new() { Text = "Contact Us" }
    })

    <div class="section-heading">
        <div class="subtitle">Get in Touch</div>
        <h2>Contact Us</h2>
    </div>

    <div class="row justify-content-center g-5">
        <div class="col-md-5">
            <div class="cart-summary">
                <h6 class="text-uppercase small fw-bold mb-4" style="letter-spacing:0.08em;">Send a Message</h6>
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success">@TempData["Success"]</div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger">@TempData["Error"]</div>
                }
                <form method="post" asp-controller="Contact" asp-action="Index">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label">Name *</label>
                        <input type="text" name="name" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Email *</label>
                        <input type="email" name="email" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Subject *</label>
                        <input type="text" name="subject" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Message *</label>
                        <textarea name="message" class="form-control" rows="5" required></textarea>
                    </div>
                    <button type="submit" class="btn btn-accent w-100 py-2">Send Message</button>
                </form>
            </div>
        </div>
        <div class="col-md-5">
            <div class="cart-summary mb-4">
                <h6 class="text-uppercase small fw-bold mb-3" style="letter-spacing:0.08em;">Contact Info</h6>
                <div class="d-flex gap-3 mb-3">
                    <div style="width:40px;height:40px;border-radius:50%;background:var(--color-accent);display:flex;align-items:center;justify-content:center;color:#fff;flex-shrink:0;">
                        <i class="bi bi-envelope"></i>
                    </div>
                    <div>
                        <div class="small text-muted">Email</div>
                        <div class="fw-medium">support@jkapparel.com</div>
                    </div>
                </div>
                <div class="d-flex gap-3 mb-3">
                    <div style="width:40px;height:40px;border-radius:50%;background:var(--color-accent);display:flex;align-items:center;justify-content:center;color:#fff;flex-shrink:0;">
                        <i class="bi bi-telephone"></i>
                    </div>
                    <div>
                        <div class="small text-muted">Phone</div>
                        <div class="fw-medium">+971 4 000 0000</div>
                    </div>
                </div>
                <div class="d-flex gap-3">
                    <div style="width:40px;height:40px;border-radius:50%;background:var(--color-accent);display:flex;align-items:center;justify-content:center;color:#fff;flex-shrink:0;">
                        <i class="bi bi-geo-alt"></i>
                    </div>
                    <div>
                        <div class="small text-muted">Address</div>
                        <div class="fw-medium">Sharjah, United Arab Emirates</div>
                    </div>
                </div>
            </div>
            <div class="cart-summary">
                <h6 class="text-uppercase small fw-bold mb-3" style="letter-spacing:0.08em;">Business Hours</h6>
                <div class="d-flex justify-content-between mb-2 small">
                    <span class="text-muted">Sunday - Thursday</span>
                    <span>9:00 AM - 6:00 PM</span>
                </div>
                <div class="d-flex justify-content-between small">
                    <span class="text-muted">Friday - Saturday</span>
                    <span>Closed</span>
                </div>
            </div>
        </div>
    </div>
</div>
