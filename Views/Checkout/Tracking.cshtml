@using ApparelShop.ViewComponents
@{
    ViewData["Title"] = "Track Order";
}

<div class="container my-5">
    @await Component.InvokeAsync("Breadcrumbs", new List<BreadcrumbItem>
    {
        new() { Text = "Home", Url = "/" },
        new() { Text = "Track Order" }
    })

    <div class="section-heading">
        <div class="subtitle">Order Status</div>
        <h2>Track Your Order</h2>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="p-4 p-md-5" style="background:#fff;border:1px solid rgba(0,0,0,0.06);border-radius:var(--radius-md);">
                <form asp-controller="Checkout" asp-action="Tracking" method="post" class="checkout-form">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label">Order Number</label>
                        <input type="text" name="orderNumber" class="form-control" placeholder="e.g. AURA-..." required />
                    </div>
                    <div class="mb-4">
                        <label class="form-label">Email Address</label>
                        <input type="email" name="email" class="form-control" placeholder="your@email.com" required />
                    </div>
                    <button type="submit" class="btn btn-accent w-100 py-3">
                        <i class="bi bi-search me-1"></i> Track Order
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
