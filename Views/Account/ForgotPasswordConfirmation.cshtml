@{ ViewData["Title"] = "Check Your Email"; }
<div class="container my-5" style="max-width:420px;">
    <div class="text-center">
        <i class="bi bi-envelope-check" style="font-size:3rem;color:var(--color-accent);"></i>
        <h2 class="mt-3 mb-3">Check Your Email</h2>
        <p class="text-muted mb-4">@ViewBag.Message</p>
        @if (ViewBag.ResetLink != null)
        {
            <div class="p-3 mb-4 text-start" style="background:#f8f7f4;border-radius:var(--radius-md);word-break:break-all;">
                <div class="small fw-bold mb-1" style="color:var(--color-accent);">Demo Reset Link:</div>
                <a href="@ViewBag.ResetLink" class="small" style="color:var(--color-primary);">@ViewBag.ResetLink</a>
            </div>
        }
        <a href="/Account/Login" class="btn btn-accent">Back to Sign In</a>
    </div>
</div>
