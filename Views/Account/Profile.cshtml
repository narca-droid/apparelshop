@model ApplicationUser
@using ApparelShop.ViewComponents
@{ ViewData["Title"] = "My Profile"; }

<div class="container my-5">
    @await Component.InvokeAsync("Breadcrumbs", new List<BreadcrumbItem>
    {
        new() { Text = "Home", Url = "/" },
        new() { Text = "My Account", Url = "/Account/Dashboard" },
        new() { Text = "Profile" }
    })

    <div class="section-heading">
        <div class="subtitle">Account Settings</div>
        <h2>My Profile</h2>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="cart-summary">
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success">@TempData["Success"]</div>
                }
                <form method="post" asp-action="Profile">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label">Full Name</label>
                        <input type="text" name="fullName" class="form-control" value="@Model.FullName" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input type="email" name="email" class="form-control" value="@Model.Email" required />
                    </div>
                    <button type="submit" class="btn btn-accent">Save Changes</button>
                    <a href="/Account/Dashboard" class="btn btn-ghost ms-2">Cancel</a>
                </form>
                <hr class="my-4" />
                <a href="/Account/ForgotPassword" class="btn btn-outline-dark-custom btn-sm">
                    <i class="bi bi-key me-1"></i> Change Password
                </a>
            </div>
        </div>
    </div>
</div>
