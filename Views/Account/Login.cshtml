@{ ViewData["Title"] = "Sign In"; }
<div class="container my-5" style="max-width:420px;">
    <div class="text-center mb-4">
        <a href="/" class="d-inline-block mb-3">
            <span style="font-family:var(--font-serif);font-size:1.8rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--color-primary);">JK Apparel</span>
        </a>
    </div>
    <h2 class="mb-4 text-center" style="font-family:var(--font-serif);">Welcome Back</h2>
    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger">
            @foreach (var e in ViewData.ModelState.Values.SelectMany(v => v.Errors))
            {
                <div>@e.ErrorMessage</div>
            }
        </div>
    }
    <form method="post" asp-action="Login" asp-route-returnUrl="@ViewBag.ReturnUrl">
        @Html.AntiForgeryToken()
        <div class="mb-3">
            <label class="form-label">Email</label>
            <input type="email" name="email" class="form-control" required autocomplete="email" />
        </div>
        <div class="mb-3">
            <label class="form-label">Password</label>
            <input type="password" name="password" class="form-control" required autocomplete="current-password" />
        </div>
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div class="form-check">
                <input type="checkbox" name="rememberMe" class="form-check-input" value="true" checked />
                <label class="form-check-label">Remember me</label>
            </div>
            <a href="/Account/ForgotPassword" class="small" style="color:var(--color-accent);">Forgot password?</a>
        </div>
        <button type="submit" class="btn btn-accent w-100 py-2">Sign In</button>
    </form>
    <p class="text-center small text-muted mt-4">Don't have an account? <a href="/Account/Register" style="color:var(--color-accent);">Create one</a></p>
</div>
