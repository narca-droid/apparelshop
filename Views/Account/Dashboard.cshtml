@model List<ApparelShop.Models.Order>
@using ApparelShop.Models
@using ApparelShop.ViewComponents
@{
    ViewData["Title"] = "My Account";
    var user = ViewBag.User as ApplicationUser;
}

<div class="container my-5">
    @await Component.InvokeAsync("Breadcrumbs", new List<BreadcrumbItem>
    {
        new() { Text = "Home", Url = "/" },
        new() { Text = "My Account" }
    })

    <div class="section-heading">
        <div class="subtitle">Welcome back</div>
        <h2>My Account</h2>
    </div>

    <div class="row g-4">
        <div class="col-md-3">
            <div class="cart-summary">
                <div class="d-flex align-items-center gap-3 mb-3 pb-3" style="border-bottom:1px solid rgba(0,0,0,0.06);">
                    <div style="width:48px;height:48px;border-radius:50%;background:var(--color-accent);display:flex;align-items:center;justify-content:center;color:#fff;font-size:1.2rem;font-weight:600;">
                        @(user?.FullName?.FirstOrDefault() ?? 'U')
                    </div>
                    <div>
                        <div class="fw-semibold" style="font-size:0.95rem;">@user?.FullName</div>
                        <div class="small text-muted">@user?.Email</div>
                    </div>
                </div>
                <nav class="d-flex flex-column gap-1">
                    <a href="/Account/Dashboard" class="btn btn-ghost text-start active" style="color:var(--color-accent);font-weight:600;">
                        <i class="bi bi-speedometer2 me-2"></i> Dashboard
                    </a>
                    <a href="/Account/Profile" class="btn btn-ghost text-start">
                        <i class="bi bi-person me-2"></i> Profile
                    </a>
                    <a href="/Wishlist" class="btn btn-ghost text-start">
                        <i class="bi bi-heart me-2"></i> Wishlist
                    </a>
                    <a href="/Checkout/Tracking" class="btn btn-ghost text-start">
                        <i class="bi bi-truck me-2"></i> Track Order
                    </a>
                    <form asp-controller="Account" asp-action="Logout" method="post" class="mt-2">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-ghost text-start text-danger">
                            <i class="bi bi-box-arrow-right me-2"></i> Sign Out
                        </button>
                    </form>
                </nav>
            </div>
        </div>

        <div class="col-md-9">
            <h5 class="mb-4" style="font-family:var(--font-serif);">Order History</h5>

            @if (!Model.Any())
            {
                <div class="text-center py-5">
                    <i class="bi bi-bag" style="font-size:3rem;color:#ddd;"></i>
                    <p class="text-muted mt-3 mb-4">You haven't placed any orders yet.</p>
                    <a href="/shop" class="btn btn-accent">Start Shopping</a>
                </div>
            }
            else
            {
                @foreach (var order in Model)
                {
                    <div class="cart-summary mb-3">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <div>
                                <span class="fw-semibold" style="font-size:0.95rem;">@order.OrderNumber</span>
                                <span class="small text-muted ms-2">@order.CreatedAt.ToString("dd MMM yyyy")</span>
                            </div>
                            <span class="badge bg-@(order.Status == OrderStatus.Delivered ? "success" : order.Status == OrderStatus.Cancelled ? "danger" : "warning")">
                                @order.Status
                            </span>
                        </div>
                        <div class="small text-muted mb-2">
                            @order.Items.Count item(s) &middot; AED @order.Total.ToString("0.00")
                        </div>
                        <a href="/Account/OrderDetails?orderNumber=@order.OrderNumber" class="btn btn-ghost small" style="color:var(--color-accent);">
                            View Details <i class="bi bi-arrow-right ms-1"></i>
                        </a>
                    </div>
                }
            }
        </div>
    </div>
</div>
